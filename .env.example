# ─────────────────────────────────────────────────────────────────────────────
# AI Agent Evaluation & Reliability Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_reliability
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/agent_reliability
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security — CHANGE IN PRODUCTION (generate with: openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Provider — Ollama (free, local, default)
# Install: https://ollama.ai  |  Pull model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.2
EVAL_JUDGE_MODEL=llama3.2

# Optional: OpenAI (only used if key is set)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Optional: Anthropic (only used if key is set)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# Observability (OpenTelemetry)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agent-reliability-platform

# PostgreSQL Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_reliability

# Frontend (used by docker-compose)
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=AI Agent Platform

# Cloud Storage (optional)
STORAGE_BACKEND=local
AZURE_STORAGE_CONNECTION_STRING=
AWS_S3_BUCKET=
