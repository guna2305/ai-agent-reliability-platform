# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_reliability
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/agent_reliability

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-me-in-production

# PostgreSQL (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_reliability
